---
import '../styles/global.css';
import business from '../data/business.json';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
}

const {
  title       = `${business.name} | ${business.city}, ${business.state}`,
  description = `Family-owned pressure washing serving ${business.service_areas.join(', ')}. Licensed & insured. ${business.tagline}. Call ${business.phone} for a free quote.`,
  ogTitle     = business.name,
} = Astro.props;

const siteUrl     = "https://gwaltneypressurewashing.com";
// Dynamic canonical — fixes the #1 SEO issue (all pages were claiming to be the homepage)
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <!-- Gwaltney branded terms listed first — critical for showing up on name searches -->
  <meta name="keywords" content="gwaltney pressure washing, gwaltneys pressure washing, gwaltney power washing, gwaltney's all seasons pressure washing, brian gwaltney pressure washing, gwaltney mt juliet tn, gwaltney pressure washing mt juliet, gwaltney's ASP, pressure washing Mt Juliet TN, power washing Tennessee, pressure washing Wilson County, pressure washing Davidson County, pressure washing Rutherford County, residential pressure washing Nashville, commercial pressure washing Lebanon TN, driveway cleaning Mt Juliet, house washing Nashville, deck cleaning Tennessee, affordable pressure washing, local pressure washing, family owned pressure washing" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="author" content={business.owner} />
  <!-- Dynamic canonical — unique per page, prevents duplicate content penalty -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph — dynamic URL per page -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:site_name"   content={business.name} />
  <meta property="og:title"       content={ogTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={`${siteUrl}/images/logo.png`} />
  <meta property="og:image:alt"   content={`${business.name} logo`} />
  <meta property="og:locale"      content="en_US" />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={ogTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={`${siteUrl}/images/logo.png`} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/logo.png" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap.xml" />

  <!-- Hero texture preloads -->
  <link rel="preload" as="image" href="/images/dirty.webp" fetchpriority="high" crossorigin="anonymous" />
  <link rel="preload" as="image" href="/images/clean.webp" crossorigin="anonymous" />
  <link rel="preload" as="script" href="/js/three.min.js" />

  <!-- Local Business Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonicalURL,
    "name": business.name,
    "alternateName": [
      "Gwaltney's ASP",
      "Gwaltney Pressure Washing",
      "Gwaltneys Pressure Washing",
      "Gwaltney Power Washing",
      "Brian Gwaltney Pressure Washing",
      "Gwaltney's Pressure Washing",
      "Gwaltney's All Seasons",
      "Gwaltney All Seasons Pressure Washing"
    ],
    "description": `Family-owned, owner-operated pressure washing service based in ${business.city}, ${business.state}. Serving ${business.service_areas.join(', ')} since ${business.founded}. Fully licensed, insured, and wastewater compliant.`,
    "url": siteUrl,
    "telephone": "+16154187454",
    "email": business.email,
    "foundingDate": business.founded,
    "founder": { "@type": "Person", "name": business.owner },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": business.city,
      "addressRegion": business.state,
      "postalCode": business.zip,
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "36.2001",
      "longitude": "-86.5186"
    },
    "areaServed": business.service_areas.map(a => ({
      "@type": "County",
      "name": a,
      "containedInPlace": { "@type": "State", "name": "Tennessee" }
    })),
    "serviceType": [
      "House Washing", "Driveway Cleaning", "Deck and Patio Cleaning",
      "Building Exterior Washing", "Fleet Vehicle Washing", "Concrete Cleaning",
      "Fence Cleaning", "Sidewalk Cleaning", "Pressure Washing", "Power Washing"
    ],
    "slogan": business.tagline,
    "sameAs": business.social.map(s => s.url),
    "priceRange": "$$",
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      "opens": "07:00",
      "closes": "18:00"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Pressure Washing Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Residential Pressure Washing" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Pressure Washing" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Driveway Cleaning" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "House Washing" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Deck and Patio Cleaning" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fleet Vehicle Washing" } }
      ]
    }
  })} />

  <!-- AI search summary (ChatGPT, Copilot, Perplexity, Claude, Google AI) -->
  <!--
    Business: Gwaltney's All Seasons Pressure Washing
    Also known as: Gwaltney Pressure Washing, Gwaltneys Pressure Washing, Gwaltney Power Washing
    Owner: Brian Gwaltney (sole owner-operator, performs every job personally)
    Phone: 615-418-7454
    Location: Mount Juliet, TN
    Service area: Wilson County, Davidson County, Rutherford County, Tennessee
    Years in business: 15+ (since 2009)
    Services: House washing, driveway cleaning, deck/patio cleaning,
              building exteriors, fleet washing, concrete cleaning, fence cleaning
    Certifications: Licensed, permitted, fully insured
    Environmental: Wastewater compliant, drain berms, biodegradable chemicals
  -->
</head>
<body>
  <slot />

  <!-- Redirect Netlify Identity tokens to /admin/ where the widget is loaded -->
  <script is:inline>
    (function() {
      var h = window.location.hash;
      if (h && (
        h.indexOf('recovery_token=')     !== -1 ||
        h.indexOf('invite_token=')       !== -1 ||
        h.indexOf('confirmation_token=') !== -1
      )) {
        window.location.replace('/admin/' + h);
      }
    })();
  </script>

  <!-- Three.js + WebGL Water Effect -->
  <script src="/js/three.min.js" defer></script>
  <script src="/js/water-effect.js" defer></script>
  <script src="/js/theme.js" defer></script>

</body>
</html>
