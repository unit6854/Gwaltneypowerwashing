---
import business from '../data/business.json';

const year = new Date().getFullYear();

const phoneIcon    = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .9h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>`;
const emailIcon    = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`;
const locationIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`;
const shieldIcon   = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`;

const socialIcons: Record<string, string> = {
  Facebook: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>`,
  Yelp:     `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14.5v-9l7 4.5-7 4.5z"/></svg>`,
  Google:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>`,
};
---

<footer class="gpw-footer" aria-label="Site footer">
  <div class="gpw-footer-grid">

    <!-- Brand -->
    <div>
      <a href="/" aria-label={`${business.name} Home`}>
        <img src="/images/logo.png" alt={business.name} class="gpw-footer-logo" width="160" height="56" loading="lazy" />
      </a>
      <p class="gpw-footer__desc">
        Family-owned pressure washing serving {business.service_areas.join(', ')}. {business.tagline} — since {business.founded}.
      </p>
      <div class="gpw-footer__social" role="list" aria-label="Social media links">
        {business.social.map((s) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.aria}
            role="listitem"
            set:html={socialIcons[s.platform] ?? ''}
          ></a>
        ))}
      </div>
    </div>

    <!-- Services -->
    <div>
      <h3 class="gpw-footer__heading">Services</h3>
      <ul class="gpw-footer__list">
        {business.footer_services.map((s) => <li><a href={s.href}>{s.label}</a></li>)}
      </ul>
    </div>

    <!-- Company -->
    <div>
      <h3 class="gpw-footer__heading">Company</h3>
      <ul class="gpw-footer__list">
        {business.footer_company.map((c) => <li><a href={c.href}>{c.label}</a></li>)}
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="gpw-footer__heading">Contact</h3>
      <address class="gpw-footer__contact-info" style="font-style:normal;">
        <div class="gpw-footer__contact-item">
          <div class="gpw-footer__contact-icon" set:html={phoneIcon}></div>
          <a href={business.phone_href}>{business.phone}</a>
        </div>
        <div class="gpw-footer__contact-item">
          <div class="gpw-footer__contact-icon" set:html={emailIcon}></div>
          <a href={`mailto:${business.email}`}>{business.email}</a>
        </div>
        <div class="gpw-footer__contact-item">
          <div class="gpw-footer__contact-icon" set:html={locationIcon}></div>
          <span>{business.address}<br/>{business.city}, {business.state} {business.zip}</span>
        </div>
      </address>

      <div class="gpw-footer__payment">
        <p class="gpw-footer__payment-label">We Accept</p>
        <p class="gpw-footer__payment-methods">
          {business.payment_methods.map((p, i) => (
            <>{p.method}{p.detail ? ` (${p.detail})` : ''}{i < business.payment_methods.length - 1 ? ' · ' : ''}</>
          ))}
        </p>
      </div>
    </div>

  </div>

  <hr class="gpw-footer__divider" />

  <div class="gpw-footer__bottom">
    <span>&copy; {year} {business.name}. All rights reserved.</span>
    <div class="gpw-footer__compliance">
      <span set:html={shieldIcon}></span>
      Licensed &amp; Insured · Wastewater Compliant · {business.city}, {business.state}
    </div>
  </div>
</footer>
