---
interface ServiceItem {
  id: string;
  icon: string;
  title: string;
  description: string;
  featured: boolean;
}
interface Props {
  data: {
    label: string;
    heading: string;
    description: string;
    items: ServiceItem[];
  };
}
const { data } = Astro.props;

const icons: Record<string, string> = {
  house: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  road: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19V5a2 2 0 012-2h12a2 2 0 012 2v14"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="4"  y1="9" x2="8"  y2="9"/><line x1="4"  y1="15" x2="8" y2="15"/><line x1="16" y1="9" x2="20" y2="9"/><line x1="16" y1="15" x2="20" y2="15"/></svg>`,
  outdoor: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3"  y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`,
  building: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="18"/><path d="M16 8h4l3 3v10h-7V8z"/><line x1="5" y1="7"  x2="5"  y2="7.01"/><line x1="9" y1="7"  x2="9"  y2="7.01"/><line x1="5" y1="11" x2="5"  y2="11.01"/><line x1="9" y1="11" x2="9"  y2="11.01"/><line x1="5" y1="15" x2="5"  y2="15.01"/><line x1="9" y1="15" x2="9"  y2="15.01"/></svg>`,
  truck: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5"  cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
  concrete: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="2"  y1="20" x2="22" y2="20"/><line x1="6"  y1="7"  x2="18" y2="7"/><line x1="6"  y1="11" x2="18" y2="11"/></svg>`,
};
---

<section class="gpw-services" id="services" aria-labelledby="services-heading">
  <div class="gpw-section-inner">
    <div class="gpw-section-header">
      <span class="gpw-label">{data.label}</span>
      <h2 id="services-heading" style="margin:0.5rem 0 0.75rem;font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:800;color:var(--gpw-white);letter-spacing:-0.02em;">{data.heading}</h2>
      <p style="color:var(--gpw-mist);max-width:60ch;font-size:1rem;line-height:1.65;margin:0;">{data.description}</p>
    </div>

    <div class="gpw-services-grid">
      {data.items.map((service) => (
        <article class={`gpw-service-card${service.featured ? ' gpw-service-card--featured' : ''}`} aria-label={service.title}>
          {service.featured && <span class="gpw-service-badge">Most Popular</span>}
          <div class="gpw-service-icon" aria-hidden="true" set:html={icons[service.icon] ?? icons.house}></div>
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
